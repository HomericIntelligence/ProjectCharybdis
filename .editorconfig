root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cpp,hpp,h,cc,cxx}]
indent_style = space
indent_size = 2

[*.{cmake,txt}]
indent_style = space
indent_size = 2

[*.{yml,yaml,json,toml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
